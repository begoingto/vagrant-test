Vagrant.configure("2") do |config|
  (1..5).each do |i|
    config.vm.define "elastic-node#{i}" do |node|
			node.vm.hostname = "elastic-node#{i}"
			node.vm.disk :disk, size: "20GB", primary: true
      node.vm.box = "bento/amazonlinux-2023"
      node.vm.box_version = "202510.26.0"
      node.vm.network "private_network", ip: "192.168.56.#{20 + i}"
      node.vm.provider "virtualbox" do |vb|
        vb.memory = "4096"
        vb.cpus = 2
      end
			node.vm.provision "shell", inline: <<-SHELL
				#!/bin/bash
				# write public key to authorized_keys
				sudo echo "ssh-rsa  x@DESKTOP-9PK4EKQ" >> /home/ec2-user/.ssh/authorized_keys
			SHELL
    end
  end
end
